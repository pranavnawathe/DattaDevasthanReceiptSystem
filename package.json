{
  "name": "datta-devasthan-receipt-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd ui && npm run dev",
    "build:ui": "cd ui && npm run build",
    "build:lambda": "cd TempleReceiptSystem/TempleReceiptSystemCDK && npm run build:lambda",
    "deploy": "cd TempleReceiptSystem/TempleReceiptSystemCDK && npm run deploy",
